<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/onboarding_default_page_header_include"
            layout="@layout/onboarding_header"
            android:layout_width="0dp"
            android:layout_height="112dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/onboarding_enable_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:src="@drawable/ic_onboarding_block_ads"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/onboarding_default_page_header_include" />

        <TextView
            android:id="@+id/onboarding_enable_title"
            style="@style/AbpOnboardingTitleTextStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/onboarding_enable_one_step_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/onboarding_enable_image"
            app:layout_constraintTop_toTopOf="@id/onboarding_enable_image" />

        <TextView
            android:id="@+id/onboarding_enable_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_enable_one_step_descriptio"
            android:textColor="@color/abp_foreground_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/onboarding_enable_title"
            app:layout_constraintTop_toBottomOf="@id/onboarding_enable_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>